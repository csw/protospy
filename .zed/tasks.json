[
  {
    "label": "protospy",
    "command": "cargo run -- --proxy name=es,port=3000,target=localhost:9200",
    "env": {
      "RUST_BACKTRACE": "1",
    },
  },
  {
    "label": "protospy tests",
    "command": "cargo test",
  },
  {
    "label": "elasticflix: run",
    "command": "uv run uvicorn elasticflix.main:app --reload",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "env": {
      "OTLP_ENDPOINT": "http://localhost:4318",
    },
  },
  {
    "label": "elasticflix: pytest tests",
    "command": "uv run pytest",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "env": {
      "OTLP_ENDPOINT": "http://localhost:4318",
      "DEBUG": "1",
    },
  },
  {
    "label": "conformance tests",
    "command": "uv run pytest -q -r pxf --findings",
    "cwd": "$ZED_WORKTREE_ROOT/conformance",
  },
  {
    "label": "conformance tests (verbose)",
    "command": "uv run pytest -v --findings",
    "cwd": "$ZED_WORKTREE_ROOT/conformance",
  },
]
