[
  {
    "label": "protospy",
    "command": "cargo run -- --console --proxy name=es,port=3000,target=localhost:9200",
    "env": {
      "RUST_BACKTRACE": "1",
      "RUST_LOG": "info,protospy=info",
    },
  },
  {
    "label": "protospy tests",
    "command": "cargo test",
  },
  {
    "label": "protospy-ext",
    "command": "cargo run -- --proxy=name=good,port=7400,target=127.0.0.1:7300 --proxy=name=wire,port=7401,target=127.0.0.1:7301 --proxy=name=dead,port=7402,target=127.0.0.1:7399",
    "env": {
      "RUST_BACKTRACE": "1",
    },
  },
  {
    "label": "elasticflix: run",
    "command": "uv run uvicorn elasticflix.main:app --reload",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "env": {
      "OTLP_ENDPOINT": "http://localhost:4318",
    },
  },
  {
    "label": "elasticflix: pytest tests",
    "command": "uv run pytest",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "env": {
      "OTLP_ENDPOINT": "http://localhost:4318",
      "DEBUG": "1",
    },
  },
  {
    "label": "conformance tests",
    "command": "uv run pytest -q -r pxEf --findings",
    "cwd": "$ZED_WORKTREE_ROOT/conformance",
  },
  {
    "label": "conformance: protospy",
    "command": "uv run pytest -n 1 -q -r pxEf --proxy protospy --findings",
    "cwd": "$ZED_WORKTREE_ROOT/conformance",
  },
  {
    "label": "conformance tests (verbose)",
    "command": "uv run pytest -v --findings",
    "cwd": "$ZED_WORKTREE_ROOT/conformance",
  },
]
