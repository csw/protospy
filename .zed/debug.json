// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug: protospy",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/protospy",
    "args": [
      "--proxy",
      "name=es,port=3000,target=localhost:9200",
      "--print-messages",
    ],
    "sourceLanguages": ["rust"],
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Debug: protospy tests",
    "adapter": "CodeLLDB",
    "build": {
      "command": "cargo",
      "args": ["test", "--no-run"],
    },
    "sourceLanguages": ["rust"],
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Debug: protospy-ext",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/protospy",
    "args": [
      "--proxy=name=good,port=7400,target=127.0.0.1:7300",
      "--proxy=name=wire,port=7401,target=127.0.0.1:7301",
      "--proxy=name=dead,port=7402,target=127.0.0.1:7399",
    ],
    "sourceLanguages": ["rust"],
    "env": { "ENV": "development" },
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Debug: conformance protospy",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "pytest",
    "args": ["-n", "0", "--proxy=protospy", "-k", "via-appended-to-response"],
    "cwd": "${ZED_WORKTREE_ROOT}/conformance",
  },
]
