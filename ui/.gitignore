node_modules/
dist/**/*
!dist/.keep
dist-ssr/
*.local
test-results/
playwright-report/
coverage/
/stats.html

# Backstop against stray visual-verify / ad-hoc screenshots (handle-ticket step 4).
# Captures are meant to land in gitignored dirs (.playwright-cli/, test-results/);
# the leak is a bare relative --filename, which writes to the process cwd — the
# `ui/` root. Scoped to the root (not **/*.png) so it catches that stray without
# ignoring legitimate PNG assets in subdirs (ui/public/, ui/src/assets/, …). A
# genuine PNG asset directly at ui/ root can still be force-added with
# `git add -f`. See PRO-348.
/*.png

# One-off performance bench scripts — not CI gates.
browser/bench-*.spec.ts

# Agent screenshot/visual-diff scratch and reg-cli artifacts (see PRO-416 note)
scratch/
reg.json

# reg-suit working dir and capture output (actualDir) — visual regression runs
# in CI; these are transient artifacts, never committed (PRO-428).
.reg/
.reg-actual/
