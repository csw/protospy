set dotenv-load
set dotenv-filename := ".env.dev"

default: run

# Ensure dependencies are installed (fast no-op when node_modules is current)
install:
    pnpm install --frozen-lockfile --config.confirm-modules-purge=false

# Run the UI dev server
run: install
    pnpm dev

# Build the UI
build: install
    pnpm run build

# Run unit + component tests with coverage (Vitest)
test-coverage: install
    pnpm test:coverage --run

# Run Playwright browser tests (browsers must be installed: pnpm exec playwright install)
test-browser: install
    pnpm test:browser --reporter=dot

# Regenerate hero screenshots (output: docs/screenshots/); run from repo root via `just screenshots`
screenshots: install
    pnpm run screenshots

# Regenerate the UI screenshot bestiary
# Output: $HOME/obsidian/protospy/Claude/screenshots/bestiary/ (override with BESTIARY_OUT)
screenshots-bestiary: install
    pnpm run screenshots:bestiary
