{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["~/.cache/uv", "~/.cargo", "~/.cache/pre-commit"],
      "denyRead": ["~/.ssh/id_rsa", "~/.ssh/id_ed25519", "~/.aws/credentials"]
    },
    "network": {
      "allowedDomains": [
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "pypi.org",
        "files.pythonhosted.org",
        "astral.sh",
        "github.com"
      ],
      "allowLocalBinding": true
    }
  }
}
