{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "pypi.org",
        "files.pythonhosted.org",
        "astral.sh",
        "github.com",
        "api.github.com",
        "api.linear.app",
        "registry.npmjs.org"
      ]
    }
  }
}