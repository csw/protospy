#!/usr/bin/env bash
#
# Wait for protospy body content to finish loading before a screenshot — so a
# shot captures rendered content, not a loading skeleton. Shared by `capture-shot`
# and the ad-hoc capture path so the rule lives in one place.
#
# The body pane decodes asynchronously (JSON in a Web Worker, compressed bodies
# via WASM, images as <img>); while that work is in flight the region marks
# itself `aria-busy="true"` (design-system §4.5). Keying on `aria-busy` covers
# every loading state — decode skeleton, lifecycle spinner, "Awaiting response…"
# /"Streaming…" — with one check, and ignores intentional animations (the
# live-stream dot, the streaming-text cursor), which are not busy regions.
#
# Order matters: the `aria-busy` detach wait resolves instantly if no region is
# busy *yet*, so this first waits for the body-owning tabpanel to be visible when
# one is present — otherwise it would pass before the skeleton even mounts and you
# screenshot the skeleton that appears a moment later. Both waits are best-effort:
# a stale skeleton is a soft defect, never a hard failure, so this always exits 0.
#
# Usage: wait-settled
#
# Requires a `playwright-cli` session already pointed at the running UI (the same
# session you capture from). See the `protospy-screenshot` skill.
set -euo pipefail

here="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=scripts/agents/_screenshot-js.sh
source "$here/_screenshot-js.sh"

# The settle JS is shared with `capture-shot` (see _screenshot-js.sh). Best-effort:
# a stale skeleton is a soft defect, never a hard failure, so always exit 0.
playwright-cli run-code "async page => {
$(js_wait_settled)
}" >/dev/null 2>&1 || true
