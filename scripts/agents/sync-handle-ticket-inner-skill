#!/usr/bin/env python3
"""Generate the handle-ticket-inner skills from the unified Jinja2 template."""

from __future__ import annotations

import argparse
import difflib
import subprocess
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
TEMPLATE = REPO_ROOT / ".claude/skills/handle-ticket-inner/SKILL.md.j2"
CLAUDE_SKILL = REPO_ROOT / ".claude/skills/handle-ticket-inner/SKILL.md"
CODEX_SKILL = REPO_ROOT / ".agents/skills/handle-ticket-inner/SKILL.md"

CLAUDE_FRONTMATTER = """---
name: handle-ticket-inner
description: Internal execution workflow for handle-ticket. Use only after handle-ticket has entered the Claude Code ticket worktree; do not invoke directly from the main checkout.
argument-hint: PRO-NNN [directions…]
arguments: [ticket]
---"""

CODEX_FRONTMATTER = """---
name: handle-ticket-inner
description: Internal execution workflow for handle-ticket. Use only after handle-ticket has placed the run in an isolated worktree-backed thread; do not invoke directly from the main checkout.
argument-hint: PRO-NNN [directions…]
arguments: [ticket]
disable-model-invocation: true
---"""

GENERATED_NOTICE = (
    "<!-- Generated by scripts/agents/sync-handle-ticket-inner-skill from "
    ".claude/skills/handle-ticket-inner/SKILL.md.j2. Do not edit directly. -->"
)


def _render(harness: str) -> str:
    result = subprocess.run(
        [
            "uvx", "--from", "jinja2-cli", "jinja2",
            "--trim-blocks",
            "--lstrip-blocks",
            "--strict",
            "-D", f"harness={harness}",
            str(TEMPLATE),
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout


def _prettify(content: str, path: Path) -> str:
    result = subprocess.run(
        ["pnpm", "exec", "prettier", "--stdin-filepath", str(path)],
        input=content,
        capture_output=True,
        text=True,
        check=True,
        cwd=REPO_ROOT / "ui",
    )
    return result.stdout


def generate_claude_skill() -> str:
    body = _render("claude")
    return _prettify(f"{CLAUDE_FRONTMATTER}\n\n{body}", CLAUDE_SKILL)


def generate_codex_skill() -> str:
    body = _render("codex")
    return _prettify(f"{CODEX_FRONTMATTER}\n\n{GENERATED_NOTICE}\n\n{body}", CODEX_SKILL)


def check() -> bool:
    ok = True
    for path, generator in [
        (CODEX_SKILL, generate_codex_skill),
        (CLAUDE_SKILL, generate_claude_skill),
    ]:
        expected = generator()
        actual = path.read_text() if path.exists() else ""
        if actual == expected:
            continue
        ok = False
        diff = difflib.unified_diff(
            actual.splitlines(keepends=True),
            expected.splitlines(keepends=True),
            fromfile=str(path),
            tofile=f"{path} (generated)",
        )
        sys.stderr.writelines(diff)
    return ok


def write() -> None:
    for path, generator in [
        (CODEX_SKILL, generate_codex_skill),
        (CLAUDE_SKILL, generate_claude_skill),
    ]:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(generator())


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate handle-ticket-inner skills from the Jinja2 template."
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="fail if either generated skill is stale",
    )
    args = parser.parse_args()

    if args.check:
        if check():
            return 0
        print(
            "handle-ticket-inner skills are stale. Run "
            "`scripts/agents/sync-handle-ticket-inner-skill` and commit the result.",
            file=sys.stderr,
        )
        return 1

    write()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
