def parse_frontmatter(source: str) -> str:
    if not source.startswith("---\n"):
        raise ValueError(f"{CLAUDE_SKILL}: missing YAML frontmatter")

    end = source.find("\n---\n", 4)
    if end == -1:
        raise ValueError(f"{CLAUDE_SKILL}: unterminated YAML frontmatter")
    return source[end + len("\n---\n") :].lstrip("\n")


def replace_once(text: str, old: str, new: str) -> str:
    if old not in text:
        raise ValueError(f"expected source block was not found:\n{old}")
    return text.replace(old, new, 1)


def replace_step_2(text: str) -> str:
    pattern = re.compile(r"## 2 — Verify the worktree and branch\n\n.*?\n---", re.S)
    text, count = pattern.subn(CODEX_STEP_2, text, count=1)
    if count != 1:
        raise ValueError("expected exactly one step-2 section")
    return text


def generate_codex_skill() -> str:
    body = parse_frontmatter(CLAUDE_SKILL.read_text())
    for old, new in TEXT_REPLACEMENTS:
        body = replace_once(body, old, new)
    body = replace_step_2(body)
    return f"{CODEX_FRONTMATTER}\n\n{GENERATED_NOTICE}\n\n{body}"


def check() -> bool:
    expected = generate_codex_skill()
    actual = CODEX_SKILL.read_text() if CODEX_SKILL.exists() else ""
    if actual == expected:
        return True

    diff = difflib.unified_diff(
        actual.splitlines(keepends=True),
        expected.splitlines(keepends=True),
        fromfile=str(CODEX_SKILL),
        tofile=f"{CODEX_SKILL} (generated)",
    )
    sys.stderr.writelines(diff)
    return False


def write() -> None:
    CODEX_SKILL.parent.mkdir(parents=True, exist_ok=True)
    CODEX_SKILL.write_text(generate_codex_skill())


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--check",
        action="store_true",
        help="fail if the generated Codex handle-ticket-inner skill is stale",
    )
    args = parser.parse_args()

    if args.check:
        if check():
            return 0
        print(
            "Codex handle-ticket-inner skill is stale. Run "
            "`scripts/agents/sync-handle-ticket-inner-skill` and commit the "
            "result.",
            file=sys.stderr,
        )
        return 1

    write()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
