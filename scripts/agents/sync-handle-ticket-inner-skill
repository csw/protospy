#!/usr/bin/env python3
"""Generate Codex handle-ticket-inner skill from Claude source using jinja2."""
# /// script
# dependencies = ["jinja2"]
# ///

from __future__ import annotations
import argparse, difflib, sys
from pathlib import Path
from jinja2 import Environment, FileSystemLoader

REPO_ROOT = Path(__file__).resolve().parents[2]
TEMPLATE_PATH = REPO_ROOT / ".claude/skills/handle-ticket-inner/SKILL.md.j2"
CODEX_SKILL = REPO_ROOT / ".agents/skills/handle-ticket-inner/SKILL.md"

CODEX_FRONTMATTER = """---
name: handle-ticket-inner
description: Internal execution workflow for handle-ticket. Use only after handle-ticket has placed the run in an isolated worktree-backed thread; do not invoke directly from the main checkout.
argument-hint: PRO-NNN [directions…]
arguments: [ticket]
disable-model-invocation: true
---"""

GENERATED_NOTICE = "<!-- Generated by scripts/agents/sync-handle-ticket-inner-skill from .claude/skills/handle-ticket-inner/SKILL.md.j2. Do not edit directly. -->"

def render_skill(harness: str) -> str:
    if not TEMPLATE_PATH.exists():
        raise FileNotFoundError(f"Template not found: {TEMPLATE_PATH}")
    env = Environment(loader=FileSystemLoader(TEMPLATE_PATH.parent))
    template = env.get_template(TEMPLATE_PATH.name)
    return template.render(harness=harness)

def extract_body(text: str) -> str:
    if not text.startswith("---\n"):
        raise ValueError("missing YAML frontmatter")
    end = text.find("\n---\n", 4)
    if end == -1:
        raise ValueError("unterminated YAML frontmatter")
    return text[end + 5:].lstrip("\n")

def generate_codex_skill() -> str:
    body = render_skill("codex")
    codex_body = extract_body(body)
    return f"{CODEX_FRONTMATTER}\n\n{GENERATED_NOTICE}\n\n{codex_body}"

def check() -> bool:
    expected = generate_codex_skill()
    actual = CODEX_SKILL.read_text() if CODEX_SKILL.exists() else ""
    if actual == expected:
        return True
    diff = difflib.unified_diff(actual.splitlines(keepends=True), expected.splitlines(keepends=True), fromfile=str(CODEX_SKILL), tofile=f"{CODEX_SKILL} (generated)")
    sys.stderr.writelines(diff)
    return False

def write() -> None:
    CODEX_SKILL.parent.mkdir(parents=True, exist_ok=True)
    CODEX_SKILL.write_text(generate_codex_skill())

def main() -> int:
    parser = argparse.ArgumentParser(description="Generate Codex skill from jinja2 template")
    parser.add_argument("--check", action="store_true", help="fail if the generated Codex skill is stale")
    args = parser.parse_args()
    if args.check:
        if check():
            return 0
        print("Codex skill is stale. Run `uvx --with jinja2 python3 scripts/agents/sync-handle-ticket-inner-skill` and commit.", file=sys.stderr)
        return 1
    write()
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
