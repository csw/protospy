#!/usr/bin/env bash
#
# Set the protospy UI theme through the next-themes test bridge and verify it
# took — so callers don't have to repeat the bridge-wait / settle / verify dance
# before every screenshot.
#
# Theme moved out of the Zustand store with the v2.3 next-themes swap (PRO-345):
# the dev/test-only `window.__test_theme` bridge owns it, and both the bridge and
# the `.dark` class on <html> are applied by React effects. So this waits for the
# bridge to mount, sets the preference, waits for it to settle, then — for an
# explicit light/dark target — asserts the resolved `.dark` class. It exits
# non-zero if the theme never takes, so a shot is never captured under the wrong
# theme. (For `system` the resolved theme depends on the emulated color scheme,
# so only the preference is verified, not the class.)
#
# Usage: set-theme <light|dark|system>
#
# Requires a `playwright-cli` session already pointed at the running UI (the same
# session you capture from). See the `protospy-screenshot` skill.
set -euo pipefail

theme="${1:-}"
case "$theme" in
  light | dark | system) ;;
  *)
    echo "usage: $(basename "$0") <light|dark|system>" >&2
    exit 2
    ;;
esac

# Wait for the bridge to mount, set the preference, wait for it to settle, then
# confirm the resolved `.dark` class for an explicit target. (For 'system' the
# resolved theme depends on the emulated color scheme, so only the preference is
# waited on, not the class.) Any failure — a `waitFor` timeout or the explicit
# mismatch throw — surfaces as `--json` `isError: true`; a clean run omits it.
# `run-code` always exits 0, so that boolean (checked below) is the enforcement.
# (A returned sentinel won't do: the CLI double-stringifies return values, e.g.
# 'ok' comes back as "\"ok\"", so `isError` is the robust signal.)
result="$(playwright-cli run-code --json "async page => {
  await page.waitForFunction(() => window.__test_theme != null, { timeout: 10000 });
  await page.evaluate(() => window.__test_theme.setTheme('$theme'));
  await page.waitForFunction(() => window.__test_theme.theme === '$theme', { timeout: 10000 });
  if ('$theme' !== 'system') {
    const isDark = await page.evaluate(() => document.documentElement.classList.contains('dark'));
    if (isDark !== ('$theme' === 'dark')) throw new Error('resolved theme is not $theme');
  }
}")"

if ! jq -e '.isError != true' <<<"$result" >/dev/null 2>&1; then
  echo "set-theme: theme '$theme' did not activate: $result" >&2
  exit 1
fi
