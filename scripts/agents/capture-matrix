#!/usr/bin/env python3
"""Capture a screenshot matrix against the running app.

Usage:
    capture-matrix --out <dir>                 # every scene the app exposes
    capture-matrix --spec <spec-file> --out <dir>   # an explicit cell list

With no `--spec`, this captures EVERY scene the running app exposes (via the
`scene-list` helper) at the default width/theme — so the captured set is the whole
app, with nothing to hand-list and nothing to get wrong. This is the normal mode:
the before pass (against the base app) and the after pass (against this branch)
each capture their own full set, so a view this branch ADDS lands only in the
after set and one it REMOVES lands only in the before set — `screenshot-diff` then
derives new vs removed from which directory holds each file. No spec, no delta
annotation, no scene-list bookkeeping.

`--spec` is an optional override for when a ticket needs specific dimensions (a
non-default width, or light theme): give a spec of `scene width theme` cells and
exactly those are captured instead of the full set.

Either way this cleans the output directory and produces one canonical shot per
cell via `capture-shot` (which derives the filename and enforces scene + theme),
so:

  - filenames are derived, never hand-typed, so a shot can't be misnamed;
  - the output dir holds exactly this run's shots, so no stale artifact survives;
  - the same app, captured before and after a change, yields filenames that pair
    for diffing by construction.

Spec format — one cell per line, whitespace-separated; blank lines and `#`
comments ignored:

    # scene            width  theme
    exchanges-active   1280   dark
    timeline-view      1440   light

A cell whose scene id is unknown to the running app (capture-shot exits 3) is
SKIPPED and reported, not an error — so a stale spec entry doesn't abort the run.
Any other capture-shot failure (theme didn't activate, screenshot failed, …)
aborts rather than leaving a partial set.

Prints each produced filename to stdout (a summary, and any skips, to stderr).
Requires a `playwright-cli` session already pointed at the running UI. See the
`protospy-screenshot` skill.
"""

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from pathlib import Path


THEMES = {"light", "dark"}

# Width/theme for the no-spec full-set capture: one representative shot per scene
# is enough to show a reviewer what changed; a ticket needing other dimensions
# passes an explicit --spec.
DEFAULT_WIDTH = "1280"
DEFAULT_THEME = "dark"

# capture-shot's exit code for "scene id unknown to the running app" — skip, not
# abort. Keep in sync with capture-shot's header.
UNKNOWN_SCENE_EXIT = 3


class SpecError(ValueError):
    """A malformed spec line; message is agent-facing."""


def parse_cell(line: str) -> dict | None:
    """Parse one spec line into a cell dict, or None for a blank/comment line.

    Raises SpecError with an actionable message on a malformed line.
    """
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        return None

    fields = stripped.split()
    if len(fields) != 3:
        raise SpecError(
            f"want 'scene width theme', got {len(fields)} field(s): {stripped!r}"
        )

    scene, width, theme = fields
    if not width.isdigit():
        raise SpecError(f"width must be a number, got {width!r}: {stripped!r}")
    if theme not in THEMES:
        raise SpecError(
            f"theme must be one of {sorted(THEMES)}, got {theme!r}: {stripped!r}"
        )

    return {"scene": scene, "width": width, "theme": theme}


def parse_spec(text: str) -> list[dict]:
    """Parse a whole spec into cells, raising SpecError (with the 1-based line
    number) on the first malformed line."""
    cells = []
    for lineno, line in enumerate(text.splitlines(), start=1):
        try:
            cell = parse_cell(line)
        except SpecError as exc:
            raise SpecError(f"line {lineno}: {exc}") from None
        if cell is not None:
            cells.append(cell)
    return cells


def running_app_scenes() -> set[str] | None:
    """Return the running app's scene ids via the `scene-list` helper, or None if
    the app doesn't expose the harness (so the caller can report it)."""
    scene_list = Path(__file__).with_name("scene-list")
    result = subprocess.run([str(scene_list)], capture_output=True, text=True)
    if result.returncode != 0:
        return None
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def full_set_cells() -> list[dict] | None:
    """All scenes the running app exposes, at the default width/theme, sorted —
    or None if the app doesn't expose the scene harness."""
    scenes = running_app_scenes()
    if scenes is None:
        return None
    return [
        {"scene": scene, "width": DEFAULT_WIDTH, "theme": DEFAULT_THEME}
        for scene in sorted(scenes)
    ]


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Capture a screenshot matrix against the running app."
    )
    parser.add_argument(
        "--spec",
        help="optional spec of `scene width theme` cells; omit to capture every "
        "scene the app exposes at the default width/theme",
    )
    parser.add_argument("--out", required=True, help="output directory")
    args = parser.parse_args(argv)

    if args.spec is not None:
        spec_path = Path(args.spec)
        if not spec_path.is_file():
            print(f"capture-matrix: spec file not found: {spec_path}", file=sys.stderr)
            return 2
        try:
            cells = parse_spec(spec_path.read_text())
        except SpecError as exc:
            print(f"capture-matrix: malformed spec: {exc}", file=sys.stderr)
            return 1
        if not cells:
            print(f"capture-matrix: spec '{spec_path}' has no cells", file=sys.stderr)
            return 1
    else:
        cells = full_set_cells()
        if cells is None:
            print(
                "capture-matrix: cannot enumerate scenes — the running app does not "
                "expose the scene harness (window.__test_scenes). Start a dev/test "
                "build, or pass an explicit --spec.",
                file=sys.stderr,
            )
            return 1
        if not cells:
            print(
                "capture-matrix: the running app exposes no scenes", file=sys.stderr
            )
            return 1

    out = Path(args.out)
    # Own the output directory: a fresh dir means the captured set is exactly this
    # run's shots, with no stale artifact surviving from a prior run.
    shutil.rmtree(out, ignore_errors=True)
    out.mkdir(parents=True, exist_ok=True)

    capture_shot = Path(__file__).with_name("capture-shot")

    captured = 0
    skipped: list[dict] = []
    for cell in cells:
        # capture-shot validates width/theme and enforces scene + theme. Exit 3
        # means the scene is unknown to this app version — skip it. Any other
        # non-zero aborts rather than leaving a partial set.
        result = subprocess.run(
            [
                str(capture_shot),
                "--scene", cell["scene"],
                "--width", cell["width"],
                "--theme", cell["theme"],
                "--out", str(out),
            ],
            capture_output=True,
            text=True,
        )
        if result.returncode == UNKNOWN_SCENE_EXIT:
            skipped.append(cell)
            print(
                f"capture-matrix: skipped {cell['scene']} {cell['width']} "
                f"{cell['theme']} — scene absent in this app version",
                file=sys.stderr,
            )
            continue
        if result.returncode != 0:
            sys.stderr.write(result.stderr)
            print(
                f"capture-matrix: capture-shot failed for cell "
                f"{cell['scene']} {cell['width']} {cell['theme']}",
                file=sys.stderr,
            )
            return 1
        sys.stdout.write(result.stdout)
        captured += 1

    summary = f"capture-matrix: captured {captured} shot(s) into {out}"
    if skipped:
        summary += f"; skipped {len(skipped)} absent in this app version"
    print(summary, file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
