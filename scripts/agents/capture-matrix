#!/usr/bin/env bash
#
# Capture a whole screenshot matrix from a spec, deterministically — so the
# captured set IS the spec. Reads a spec of `scene width theme` cells, cleans the
# output directory, and produces exactly one canonical shot per cell via
# capture-shot (which derives the filename and verifies scene + theme). This makes
# three things structural rather than checked-after-the-fact:
#   - filenames are derived, never hand-typed, so a shot can't be misnamed;
#   - the output dir holds exactly the spec, so no stale artifact survives;
#   - a before and an after pass driven by the SAME spec produce identical
#     filenames, so the two sets pair for diffing by construction.
#
# Spec format: one cell per line, whitespace-separated `scene width theme`. Blank
# lines and `#` comments are ignored. Example:
#
#   # scene            width  theme
#   exchanges-active   1280   dark
#   detail-panel       1280   dark
#
# Usage: capture-matrix --spec <spec-file> --out <dir>
#
# Prints each produced filename to stdout (a summary to stderr). Requires a
# playwright-cli session already pointed at the running UI. See the
# protospy-screenshot skill.
set -euo pipefail

spec="" out=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --spec) spec="$2"; shift 2 ;;
    --out) out="$2"; shift 2 ;;
    *) echo "capture-matrix: unknown argument: $1" >&2; exit 2 ;;
  esac
done

[[ -n "$spec" && -n "$out" ]] || {
  echo "usage: $(basename "$0") --spec <spec-file> --out <dir>" >&2
  exit 2
}
[[ -f "$spec" ]] || {
  echo "capture-matrix: spec file not found: $spec" >&2
  exit 2
}

here="$(cd "$(dirname "$0")" && pwd)"

# Own the output directory: a fresh dir means the captured set is exactly the
# spec, with no stale artifact surviving from a prior pass.
rm -rf "$out"
mkdir -p "$out"

count=0
while read -r scene width theme rest || [[ -n "$scene" ]]; do
  # Skip blank lines and `#` comments before validating cell shape.
  [[ -z "$scene" || "$scene" == \#* ]] && continue
  if [[ -z "$width" || -z "$theme" || -n "$rest" ]]; then
    echo "capture-matrix: malformed spec line (want 'scene width theme'): $scene $width $theme $rest" >&2
    exit 1
  fi
  # capture-shot validates width/theme and enforces scene + theme; a failure here
  # aborts the whole pass under set -e rather than leaving a partial set.
  "$here/capture-shot" --scene "$scene" --width "$width" --theme "$theme" --out "$out"
  count=$((count + 1))
done < "$spec"

if [[ "$count" -eq 0 ]]; then
  echo "capture-matrix: spec '$spec' has no cells" >&2
  exit 1
fi

echo "capture-matrix: captured $count shot(s) into $out" >&2
