#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "boto3>=1.43,<2",
# ]
# ///
"""Upload screenshots to S3 and print Markdown image embeds.

Usage:
    upload-screenshot <path> [--branch BRANCH]

<path> may be a single image file or a directory. For a directory, all
image files (*.png, *.jpg, *.jpeg, *.webp) directly inside it are uploaded
(non-recursive). Prints one Markdown image embed string per file:

    ![filename](https://protospy-dev-data.s3.amazonaws.com/screenshots/pr-BRANCH/filename)
"""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path


BUCKET = "protospy-dev-data"
KEY_PREFIX = "screenshots"
IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".webp"}

CONTENT_TYPES = {
    ".png": "image/png",
    ".jpg": "image/jpeg",
    ".jpeg": "image/jpeg",
    ".webp": "image/webp",
}


def current_branch() -> str:
    result = subprocess.run(
        ["git", "branch", "--show-current"],
        capture_output=True,
        text=True,
        check=True,
    )
    branch = result.stdout.strip()
    if not branch:
        raise SystemExit(
            "error: could not determine current branch; pass --branch explicitly"
        )
    return branch


def branch_slug(branch: str) -> str:
    slug = re.sub(r"[^A-Za-z0-9._-]+", "-", branch)
    return slug.strip("-") or "unknown"


def s3_url(bucket: str, key: str) -> str:
    return f"https://{bucket}.s3.amazonaws.com/{key}"


def collect_images(path: Path) -> list[Path]:
    if path.is_file():
        if path.suffix.lower() in IMAGE_EXTS:
            return [path]
        print(
            f"warning: {path} is not a recognised image type, skipping",
            file=sys.stderr,
        )
        return []
    if path.is_dir():
        return sorted(
            p
            for p in path.iterdir()
            if p.is_file() and p.suffix.lower() in IMAGE_EXTS
        )
    raise SystemExit(f"error: {path}: no such file or directory")


def upload(images: list[Path], slug: str) -> list[str]:
    import boto3  # noqa: PLC0415

    s3 = boto3.client("s3")
    embeds = []
    for image in images:
        key = f"{KEY_PREFIX}/pr-{slug}/{image.name}"
        content_type = CONTENT_TYPES.get(image.suffix.lower(), "image/png")
        s3.upload_file(
            str(image),
            BUCKET,
            key,
            ExtraArgs={"ContentType": content_type},
        )
        embeds.append(f"![{image.name}]({s3_url(BUCKET, key)})")
    return embeds


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Upload screenshot(s) to S3 and print Markdown image embeds."
    )
    parser.add_argument("path", help="image file or directory of images to upload")
    parser.add_argument(
        "--branch",
        help=(
            "branch/PR identifier for the S3 key prefix "
            "(default: current git branch)"
        ),
    )
    args = parser.parse_args(argv)

    path = Path(args.path)
    branch = args.branch or current_branch()
    slug = branch_slug(branch)
    images = collect_images(path)
    if not images:
        print("no images found", file=sys.stderr)
        return 1

    embeds = upload(images, slug)
    for embed in embeds:
        print(embed)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
