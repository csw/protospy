#!/usr/bin/env python3
"""Generate Codex agent TOML files from Claude agent Markdown sources."""

from __future__ import annotations

import argparse
import difflib
import json
import re
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
CLAUDE_AGENTS = REPO_ROOT / ".claude" / "agents"
CODEX_AGENTS = REPO_ROOT / ".codex" / "agents"

IMPLEMENTER_AGENT_NAMES = (
    "convention-review",
    "design-system-conformance-review",
    "qa-explorer",
    "review-synthesis",
    "setup-scout",
    "visual-review",
)

CODEX_MODEL_BY_CLAUDE_MODEL = {
    "haiku": "gpt-5.4-mini",
    "sonnet": "gpt-5.4-mini",
}


def map_claude_model_to_codex_model(claude_model: str, source_path: Path) -> str:
    codex_model = CODEX_MODEL_BY_CLAUDE_MODEL.get(claude_model)
    if codex_model:
        return codex_model

    if "opus" in claude_model.lower():
        return "gpt-5.5"

    raise ValueError(
        f"{source_path}: no Codex model mapping for Claude model {claude_model!r}"
    )


def parse_frontmatter(source: str, path: Path) -> tuple[dict[str, str], str]:
    if not source.startswith("---\n"):
        raise ValueError(f"{path}: missing YAML frontmatter")

    end = source.find("\n---\n", 4)
    if end == -1:
        raise ValueError(f"{path}: unterminated YAML frontmatter")

    frontmatter = source[4:end]
    body = source[end + len("\n---\n") :]
    return parse_simple_yaml(frontmatter, path), body.lstrip("\n")


def parse_simple_yaml(text: str, path: Path) -> dict[str, str]:
    """Parse the small YAML subset used by the agent frontmatter."""

    result: dict[str, str] = {}
    lines = text.splitlines()
    index = 0

    while index < len(lines):
        line = lines[index]
        if not line.strip():
            index += 1
            continue

        match = re.match(r"^([A-Za-z][A-Za-z0-9_-]*):(.*)$", line)
        if not match:
            raise ValueError(f"{path}: unsupported frontmatter line: {line!r}")

        key, raw_value = match.groups()
        value = raw_value.strip()
        index += 1

        if value in {">", ">-"}:
            folded: list[str] = []
            while index < len(lines):
                next_line = lines[index]
                if next_line and not next_line.startswith((" ", "\t")):
                    break
                folded.append(next_line.strip())
                index += 1
            result[key] = " ".join(part for part in folded if part)
            continue

        if value == "":
            block: list[str] = []
            while index < len(lines):
                next_line = lines[index]
                if next_line and not next_line.startswith((" ", "\t")):
                    break
                block.append(next_line.strip())
                index += 1
            result[key] = "\n".join(block)
            continue

        result[key] = value.strip("\"'")

    return result


def translate_body(body: str) -> str:
    translations = (
        ("CLAUDE.md", "AGENTS.md"),
        ("~/obsidian/protospy/Claude/Reviews", "$VAULT_BASE/Reviews"),
    )
    for source, replacement in translations:
        body = body.replace(source, replacement)
    return body.rstrip() + "\n"


def generate_agent(name: str) -> str:
    source_path = CLAUDE_AGENTS / f"{name}.md"
    frontmatter, body = parse_frontmatter(source_path.read_text(), source_path)

    if frontmatter.get("name") != name:
        actual = frontmatter.get("name", "<missing>")
        raise ValueError(f"{source_path}: expected name {name!r}, got {actual!r}")

    description = frontmatter.get("description")
    if not description:
        raise ValueError(f"{source_path}: missing description")

    claude_model = frontmatter.get("model")
    codex_model = None
    if claude_model:
        codex_model = map_claude_model_to_codex_model(claude_model, source_path)

    instructions = translate_body(body)
    if '"""' in instructions:
        raise ValueError(f"{source_path}: body contains TOML triple-quote delimiter")

    model_line = f"model = {json.dumps(codex_model)}\n" if codex_model else ""

    return (
        f"# Generated by scripts/agents/sync-codex-agents from "
        f".claude/agents/{name}.md.\n"
        "# Do not edit directly; edit the Claude agent source and regenerate.\n"
        f"name = {json.dumps(name, ensure_ascii=False)}\n"
        f"description = {json.dumps(description, ensure_ascii=False)}\n"
        f"{model_line}"
        'developer_instructions = """\n'
        f"{instructions}"
        '"""\n'
    )


def check_agent(name: str) -> bool:
    path = CODEX_AGENTS / f"{name}.toml"
    expected = generate_agent(name)
    actual = path.read_text() if path.exists() else ""
    if actual == expected:
        return True

    diff = difflib.unified_diff(
        actual.splitlines(keepends=True),
        expected.splitlines(keepends=True),
        fromfile=str(path),
        tofile=f"{path} (generated)",
    )
    sys.stderr.writelines(diff)
    return False


def write_agent(name: str) -> None:
    CODEX_AGENTS.mkdir(parents=True, exist_ok=True)
    (CODEX_AGENTS / f"{name}.toml").write_text(generate_agent(name))


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--check",
        action="store_true",
        help="fail if generated Codex agents differ from checked-in files",
    )
    args = parser.parse_args()

    if args.check:
        clean = all(check_agent(name) for name in IMPLEMENTER_AGENT_NAMES)
        if not clean:
            print(
                "Codex agent definitions are stale. Run "
                "`scripts/agents/sync-codex-agents` and commit the result.",
                file=sys.stderr,
            )
            return 1
        return 0

    for name in IMPLEMENTER_AGENT_NAMES:
        write_agent(name)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
