#!/usr/bin/env python3
"""Start a ticket run in an isolated Git worktree, for Codex or Claude Code.

This launcher owns worktree placement so the harness session begins with its cwd
already inside the worktree: it resolves the ticket's branch from Linear, creates
or reuses the worktree, installs UI dependencies, then execs the harness CLI
pointed at that worktree running `handle-ticket`. Starting the session pre-placed
is the structural fix for "worktree edits leak onto the main checkout" — the
agent never has the main-checkout path in its context (PRO-376).

Codex is launched with `codex -C <worktree>`. Claude Code has no equivalent of
`-C`, so we `chdir` into the worktree and exec `claude` from there; its cwd is
then the worktree from turn one.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import unicodedata
from pathlib import Path


DEFAULT_WORKTREE_ROOT = ".worktrees"
EFFORT_LEVELS = ("minimal", "low", "medium", "high", "xhigh")
HARNESSES = ("codex", "claude")

# Per-harness defaults: CLI binary and the prompt prefix that invokes the
# handle-ticket skill (Codex uses `$name`, Claude uses `/name`).
HARNESS_BIN = {"codex": "codex", "claude": "claude"}
HARNESS_SKILL_PREFIX = {"codex": "$handle-ticket", "claude": "/handle-ticket"}


def run(
    argv: list[str],
    *,
    cwd: Path | None = None,
    capture: bool = False,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        argv,
        cwd=cwd,
        check=check,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
    )


def repo_root() -> Path:
    result = run(["git", "rev-parse", "--show-toplevel"], capture=True)
    return Path(result.stdout.strip())


def fetch_issue(ticket: str) -> dict:
    result = run(
        ["linear", "issues", "get", ticket, "--output", "json"], capture=True
    )
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"linear returned invalid JSON: {exc}") from exc


def fetch_slug(ticket: str) -> str:
    """The CLI's branch/worktree slug, e.g. ``pro-136_give_agents_...``.

    It already embeds the ``pro-NNN`` identifier (which is what Linear's GitHub
    integration matches on) and is lowercase, capped at 60 chars, and trimmed at
    whole-word boundaries, so we use it verbatim as the branch name.
    """
    result = run(["linear", "issues", "slug", ticket], capture=True)
    slug = result.stdout.strip()
    if not slug:
        raise SystemExit(f"linear returned an empty slug for {ticket}")
    return slug


def slugify(text: str) -> str:
    ascii_text = unicodedata.normalize("NFKD", text).encode("ascii", "ignore")
    slug = re.sub(r"[^a-z0-9]+", "-", ascii_text.decode().lower())
    return slug.strip("-") or "ticket"


def branch_with_suffix(branch: str, suffix_text: str) -> str:
    """Append a ``--version`` suffix to the branch (e.g. ``…_actor`` → ``…_actor_2``)."""
    return f"{branch}_{slugify(suffix_text)}"


def path_slug(branch: str) -> str:
    return re.sub(r"[^A-Za-z0-9._-]+", "-", branch).strip("-")


def local_branch_exists(root: Path, branch: str) -> bool:
    result = run(
        ["git", "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
        cwd=root,
        check=False,
    )
    return result.returncode == 0


def resolve_worktree_path(root: Path, branch: str, worktree_root: str) -> Path:
    worktree_base = Path(worktree_root)
    if not worktree_base.is_absolute():
        worktree_base = root / worktree_base
    return worktree_base / path_slug(branch)


def resolve_explicit_worktree_path(root: Path, worktree: str) -> Path:
    worktree_path = Path(worktree)
    if not worktree_path.is_absolute():
        worktree_path = root / worktree_path
    return worktree_path


def current_branch(path: Path) -> str:
    result = run(["git", "branch", "--show-current"], cwd=path, capture=True)
    return result.stdout.strip()


def ensure_worktree(root: Path, branch: str, base: str, worktree_path: Path) -> Path:
    if worktree_path.exists():
        if not worktree_path.is_dir():
            raise SystemExit(
                f"worktree path exists but is not a directory: {worktree_path}"
            )
        actual_branch = current_branch(worktree_path)
        if actual_branch != branch:
            raise SystemExit(
                f"worktree path already exists on branch {actual_branch!r}, "
                f"not {branch!r}: {worktree_path}"
            )
        return worktree_path

    worktree_path.parent.mkdir(parents=True, exist_ok=True)
    try:
        if local_branch_exists(root, branch):
            run(["git", "worktree", "add", str(worktree_path), branch], cwd=root)
        else:
            run(
                ["git", "worktree", "add", "-b", branch, str(worktree_path), base],
                cwd=root,
            )
    except subprocess.CalledProcessError as exc:
        raise SystemExit(
            f"git worktree add failed for branch {branch!r} at {worktree_path}\n"
            f"  (exit {exc.returncode}; git output is above)"
        ) from None
    return worktree_path


def worktree_add_command(
    root: Path,
    branch: str,
    base: str,
    worktree_path: Path,
) -> list[str]:
    if worktree_path.exists():
        return ["git", "-C", str(worktree_path), "status", "--short"]
    if local_branch_exists(root, branch):
        return ["git", "worktree", "add", str(worktree_path), branch]
    return ["git", "worktree", "add", "-b", branch, str(worktree_path), base]


def ui_install_command() -> list[str]:
    return ["just", "ui::install"]


def ensure_ui_dependencies(worktree_path: Path) -> None:
    run(ui_install_command(), cwd=worktree_path)


def shell_join(argv: list[str]) -> str:
    return " ".join(shlex.quote(arg) for arg in argv)


def harness_cli_args(args: argparse.Namespace) -> list[str]:
    """CLI args passed to the harness binary, before the worktree/prompt args.

    `--model` is shared by both harnesses. `--effort` maps to
    `-c model_reasoning_effort` for Codex and `--effort` for Claude Code.
    Anything in `--harness-arg`
    (or its Codex alias `--codex-arg`) and after `--` is passed through verbatim.
    """
    result: list[str] = []
    if args.plan:
        if args.harness == "codex":
            raise SystemExit(
                "--plan is not supported for Codex: it has no equivalent of "
                "--permission-mode plan (its --ask-for-approval policies are a "
                "different approval paradigm, not pre-execution plan review)"
            )
        result.extend(["--permission-mode", "plan"])
    if args.model:
        result.extend(["--model", args.model])
    if args.effort:
        if args.harness == "codex":
            result.extend(["-c", f'model_reasoning_effort="{args.effort}"'])
        else:
            result.extend(["--effort", args.effort])
    result.extend(args.harness_arg)
    result.extend(args.passthrough)
    return result


def build_prompt(ticket: str, directions: list[str], harness: str) -> str:
    prefix = HARNESS_SKILL_PREFIX[harness]
    suffix = " ".join(directions).strip()
    if suffix:
        return f"{prefix} {ticket} {suffix}"
    return f"{prefix} {ticket}"


def build_wrapper_directions(args: argparse.Namespace) -> list[str]:
    # The skill's step 1 verifies worktree placement and branch ownership, so
    # the wrapper only needs to pass signals that step 1 can't infer from git.
    directions: list[str] = []
    if args.branch_version:
        directions.append(
            f"(versioned-branch: this is version {args.branch_version} — "
            "an intentional alternate run, not the primary ticket branch)"
        )
    if args.branch:
        directions.append("(explicit-branch: preserve the exact branch name)")
    if args.worktree:
        directions.append("(explicit-worktree: preserve the exact worktree path)")
    return directions


def build_directions(
    wrapper_directions: list[str],
    instructions: list[str],
    positional_directions: list[str],
) -> list[str]:
    directions = list(wrapper_directions)
    directions.extend(
        instruction.strip()
        for instruction in instructions
        if instruction.strip()
    )
    directions.extend(positional_directions)
    return directions


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="ticket",
        description=(
            "Fetch a Linear issue, create or reuse an isolated Git worktree on "
            "Linear's branch name, then launch the chosen harness CLI in that "
            "worktree running handle-ticket."
        ),
        add_help=False,
    )
    parser.add_argument(
        "--harness",
        choices=HARNESSES,
        default="codex",
        help="harness CLI to launch in the worktree (default: codex)",
    )
    parser.add_argument(
        "--base",
        default="origin/main",
        help="base ref for new branches (default: origin/main)",
    )
    parser.add_argument(
        "--worktree-root",
        default=DEFAULT_WORKTREE_ROOT,
        help="directory for Git worktrees, relative to the repo root by default",
    )
    parser.add_argument(
        "--harness-bin",
        "--codex-bin",
        dest="harness_bin",
        default=None,
        help="harness executable to launch (defaults per --harness)",
    )
    parser.add_argument(
        "--branch",
        help=(
            "exact branch to create or reuse instead of the resolved branch "
            "name; use this to resume or create a manually named alternative "
            "branch"
        ),
    )
    parser.add_argument(
        "-v",
        "--version",
        "--branch-version",
        dest="branch_version",
        help=(
            "append a short suffix to the resolved branch name before "
            "creating or reusing the worktree, e.g. --version 2"
        ),
    )
    parser.add_argument(
        "-i",
        "--instructions",
        action="append",
        default=[],
        help=(
            "extra instruction text passed through to handle-ticket; "
            "repeatable, and combined with any freeform words after the ticket"
        ),
    )
    parser.add_argument(
        "--worktree",
        help=(
            "explicit worktree path to create or reuse; when it already exists "
            "and --branch/--version are omitted, its current branch is used"
        ),
    )
    parser.add_argument(
        "--model",
        help="model to pass through as --model (both harnesses)",
    )
    parser.add_argument(
        "-e",
        "--effort",
        choices=EFFORT_LEVELS,
        help="reasoning effort (Codex: -c model_reasoning_effort; Claude: --effort)",
    )
    parser.add_argument(
        "--harness-arg",
        "--codex-arg",
        dest="harness_arg",
        action="append",
        default=[],
        help=(
            "extra argument passed to the harness CLI before the worktree/prompt "
            "args; repeat for multiple args"
        ),
    )
    parser.add_argument(
        "--plan",
        action="store_true",
        help=(
            "run in plan mode (Claude: --permission-mode plan; "
            "Codex: no equivalent, errors out)"
        ),
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print the worktree and launch command without launching",
    )
    parser.add_argument(
        "-h",
        "--help",
        action="store_true",
        help="show this help message",
    )

    recognized_with_values = {
        "--harness",
        "--base",
        "--worktree-root",
        "--harness-bin",
        "--codex-bin",
        "--branch",
        "-v",
        "--version",
        "--branch-version",
        "--worktree",
        "-i",
        "--instructions",
        "--model",
        "-e",
        "--effort",
        "--harness-arg",
        "--codex-arg",
    }
    recognized_flags = {"--plan", "--dry-run", "-h", "--help"}

    if "--" in argv:
        delimiter_index = argv.index("--")
        argv, passthrough = argv[:delimiter_index], argv[delimiter_index + 1 :]
    else:
        passthrough = []

    option_args: list[str] = []
    positional: list[str] = []
    index = 0
    while index < len(argv):
        arg = argv[index]

        if arg in recognized_flags:
            option_args.append(arg)
            index += 1
            continue

        if arg in recognized_with_values:
            if index + 1 >= len(argv):
                parser.error(f"argument {arg}: expected one argument")
            option_args.extend([arg, argv[index + 1]])
            index += 2
            continue

        if any(arg.startswith(f"{option}=") for option in recognized_with_values):
            option_args.append(arg)
            index += 1
            continue

        positional.append(arg)
        index += 1

    args = parser.parse_args(option_args)
    if args.help:
        parser.print_help()
        raise SystemExit(0)
    if not positional:
        parser.error("missing Linear issue identifier, e.g. PRO-123")
    args.ticket = positional[0]
    args.directions = positional[1:]
    args.passthrough = passthrough
    if args.harness_bin is None:
        args.harness_bin = HARNESS_BIN[args.harness]
    if args.branch and args.branch_version:
        parser.error("--branch and --version are mutually exclusive")
    return args


def launch_command(
    args: argparse.Namespace,
    worktree_path: Path,
    prompt: str,
) -> list[str]:
    """The exec argv for the chosen harness.

    Codex re-anchors its cwd with `-C <worktree>`. Claude Code has no such flag,
    so the caller chdir()s into the worktree first and Claude takes the prompt as
    a leading positional argument.
    """
    cli_args = harness_cli_args(args)
    if args.harness == "codex":
        return [args.harness_bin, *cli_args, "-C", str(worktree_path), prompt]
    return [args.harness_bin, *cli_args, prompt]


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    ticket = args.ticket.upper()
    root = repo_root()
    issue = fetch_issue(ticket)

    title = str(issue.get("title") or ticket)
    if args.branch:
        branch = str(args.branch).strip()
        if not branch:
            raise SystemExit("--branch must not be empty")
    else:
        branch = fetch_slug(ticket)
        if args.branch_version:
            branch = branch_with_suffix(branch, args.branch_version)

    if args.worktree:
        worktree_path = resolve_explicit_worktree_path(root, args.worktree)
        if worktree_path.exists():
            if not worktree_path.is_dir():
                raise SystemExit(
                    f"worktree path exists but is not a directory: {worktree_path}"
                )
            if not args.branch and not args.branch_version:
                branch = current_branch(worktree_path)
                if not branch:
                    raise SystemExit(
                        f"worktree has no current branch; pass --branch explicitly: "
                        f"{worktree_path}"
                    )
    else:
        worktree_path = resolve_worktree_path(root, branch, args.worktree_root)

    if not args.dry_run:
        print("fetching origin…", file=sys.stderr)
        run(["git", "fetch", "origin"], cwd=root)
        worktree_path = ensure_worktree(root, branch, args.base, worktree_path)
        ensure_ui_dependencies(worktree_path)
    prompt = build_prompt(
        ticket,
        build_directions(
            build_wrapper_directions(args),
            args.instructions,
            args.directions,
        ),
        args.harness,
    )
    launch_cmd = launch_command(args, worktree_path, prompt)

    print(f"harness: {args.harness}", file=sys.stderr)
    print(f"ticket: {ticket}", file=sys.stderr)
    print(f"title: {title}", file=sys.stderr)
    print(f"branch: {branch}", file=sys.stderr)
    print(f"worktree: {worktree_path}", file=sys.stderr)
    if args.dry_run:
        print("fetch: git fetch origin", file=sys.stderr)
        git_cmd = worktree_add_command(root, branch, args.base, worktree_path)
        print(f"git: {shell_join(git_cmd)}", file=sys.stderr)
        print(
            f"ui install: (cd {shlex.quote(str(worktree_path))} && "
            f"{shell_join(ui_install_command())})",
            file=sys.stderr,
        )
    if args.harness == "claude":
        print(
            f"launch: (cd {shlex.quote(str(worktree_path))} && "
            f"{shell_join(launch_cmd)})",
            file=sys.stderr,
        )
    else:
        print(f"launch: {shell_join(launch_cmd)}", file=sys.stderr)

    if args.dry_run:
        return 0

    # Claude Code has no -C: start it from inside the worktree so its cwd is the
    # worktree from the first turn.
    if args.harness == "claude":
        os.chdir(worktree_path)
    os.execvp(args.harness_bin, launch_cmd)
    return 127


if __name__ == "__main__":
    raise SystemExit(main())
