#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "Pillow>=11,<13",
#   "numpy>=1,<3",
# ]
# ///
"""Compare before/after screenshot directories for pixel-level differences.

Usage:
    screenshot-diff <before-dir> <after-dir> [--threshold FRACTION]
                    [--pixel-tolerance N]

<before-dir>           Directory containing "before" screenshots.
<after-dir>            Directory containing "after" screenshots.

--threshold FRACTION   Maximum allowed fraction of differing pixels per pair
                       (0.0–1.0, default 0.001 = 0.1%). Any pair that exceeds
                       this threshold causes the script to exit non-zero.

--pixel-tolerance N    Per-channel RGB tolerance: a pixel is counted as
                       "different" only when at least one channel differs by
                       more than N (0–255, default 2). Values ≤ 2 handle
                       sub-pixel rendering variance without masking real
                       changes.

Pairs images from before-dir and after-dir by filename. Files present in
before-dir but not after-dir are reported as warnings and excluded from the
pass/fail count. Files present only in after-dir are ignored silently.

Outputs a one-line summary to stdout:

    4/4 identical
    2/4 differ: light-1280.png (0.3% changed), dark-1280.png (1.2% changed)

Exits 0 if all pairs are within the threshold, 1 otherwise.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path


IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".webp"}


def compare_pair(
    before: Path,
    after: Path,
    pixel_tolerance: int,
) -> dict[str, object]:
    """Compare two images pixel-by-pixel.

    Returns a dict with:
      ok      bool   — True if dimensions match and comparison completed
      error   str    — set when ok is False
      percent float  — percentage of pixels that differ (0.0 if ok is False)
    """
    from PIL import Image  # noqa: PLC0415
    import numpy as np  # noqa: PLC0415

    try:
        img_b = Image.open(before).convert("RGB")
        img_a = Image.open(after).convert("RGB")
    except Exception as exc:  # noqa: BLE001
        return {"ok": False, "error": str(exc), "percent": 0.0}

    if img_b.size != img_a.size:
        return {
            "ok": False,
            "error": (
                f"size mismatch: before={img_b.size[0]}×{img_b.size[1]}"
                f" after={img_a.size[0]}×{img_a.size[1]}"
            ),
            "percent": 0.0,
        }

    arr_b = np.array(img_b, dtype=np.int32)
    arr_a = np.array(img_a, dtype=np.int32)
    diff = np.abs(arr_b - arr_a)
    different_pixels = int(np.any(diff > pixel_tolerance, axis=-1).sum())
    total_pixels = img_b.width * img_b.height
    percent = different_pixels / total_pixels * 100 if total_pixels else 0.0

    return {"ok": True, "error": None, "percent": percent}


def collect_images(directory: Path) -> list[Path]:
    return sorted(
        p
        for p in directory.iterdir()
        if p.is_file() and p.suffix.lower() in IMAGE_EXTS
    )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Compare before/after screenshot directories pixel-by-pixel."
    )
    parser.add_argument("before_dir", help="directory of before screenshots")
    parser.add_argument("after_dir", help="directory of after screenshots")
    parser.add_argument(
        "--threshold",
        type=float,
        default=0.001,
        metavar="FRACTION",
        help="max fraction of pixels allowed to differ (default: 0.001 = 0.1%%)",
    )
    parser.add_argument(
        "--pixel-tolerance",
        type=int,
        default=2,
        metavar="N",
        dest="pixel_tolerance",
        help="per-channel difference to ignore for sub-pixel rendering (default: 2)",
    )
    args = parser.parse_args(argv)

    if not 0.0 <= args.threshold <= 1.0:
        print(
            f"error: --threshold must be between 0.0 and 1.0, got {args.threshold}",
            file=sys.stderr,
        )
        return 2

    if not 0 <= args.pixel_tolerance <= 255:
        print(
            f"error: --pixel-tolerance must be between 0 and 255, got {args.pixel_tolerance}",
            file=sys.stderr,
        )
        return 2

    before_dir = Path(args.before_dir)
    after_dir = Path(args.after_dir)

    for d, label in [(before_dir, "before-dir"), (after_dir, "after-dir")]:
        if not d.exists():
            print(f"error: {label} does not exist: {d}", file=sys.stderr)
            return 2
        if not d.is_dir():
            print(f"error: {label} is not a directory: {d}", file=sys.stderr)
            return 2

    before_images = {p.name: p for p in collect_images(before_dir)}
    after_images = {p.name: p for p in collect_images(after_dir)}

    if not before_images:
        print(f"error: no images found in {before_dir}", file=sys.stderr)
        return 2

    # Warn about unpaired before-images
    for name in sorted(before_images):
        if name not in after_images:
            print(
                f"warning: {name} present in before/ but not after/ — skipping",
                file=sys.stderr,
            )

    # Compare paired images
    pairs = [(name, before_images[name]) for name in sorted(before_images) if name in after_images]

    if not pairs:
        print("error: no paired images to compare", file=sys.stderr)
        return 2

    results: list[dict[str, object]] = []
    for name, before_path in pairs:
        after_path = after_images[name]
        result = compare_pair(before_path, after_path, args.pixel_tolerance)
        result["name"] = name
        results.append(result)

    errors = [r for r in results if not r["ok"]]
    for r in errors:
        print(f"error: {r['name']}: {r['error']}", file=sys.stderr)

    ok_results = [r for r in results if r["ok"]]
    n_pairs = len(ok_results)
    failing = sorted(
        [r for r in ok_results if r["percent"] / 100 > args.threshold],
        key=lambda r: -r["percent"],
    )

    if not failing:
        print(f"{n_pairs}/{n_pairs} identical")
    else:
        details = ", ".join(
            f"{r['name']} ({r['percent']:.1f}% changed)" for r in failing
        )
        print(f"{len(failing)}/{n_pairs} differ: {details}")

    if errors or failing:
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
