{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "protospy: run",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=protospy"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "1",
                "RUST_LOG": "info,protospy=debug",
                "PRINT_MESSAGES": "1",
                "PROXY__ES__PORT": "3000",
                "PROXY__ES__TARGET": "localhost:9200",
                "TOKIO_CONSOLE": "1"
            }
        },
        {
            "name": "protospy-ext",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=protospy"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "full",
                "RUST_LOG": "info,protospy=debug",
                "PRINT_MESSAGES": "1",
                "PROXY__GOOD__PORT": "7400",
                "PROXY__GOOD__TARGET": "127.0.0.1:7300",
                "PROXY__WIRE__PORT": "7401",
                "PROXY__WIRE__TARGET": "127.0.0.1:7301",
                "PROXY__DEAD__PORT": "7402",
                "PROXY__DEAD__TARGET": "127.0.0.1:7302",
                "TOKIO_CONSOLE": "1"
            }
        },
        {
            "name": "Debug unit tests in executable 'protospy'",
            "type": "lldb",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "cargo": {
                "args": [
                    "test",
                    "--bin=protospy"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "full",
                "RUST_LIB_BACKTRACE": "full"
            }
        },
    ]
}