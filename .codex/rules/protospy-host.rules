prefix_rule(
    pattern = ["linear"],
    decision = "allow",
    justification = "Linear CLI uses a restricted token and needs host auth/keyring access outside the sandbox.",
    match = [
        "linear issue view PRO-356 --json",
        "linear issue update PRO-356 --state In Progress",
        "linear issue comment add PRO-356 --body-file /tmp/comment.md",
        "linear issue pull-request PRO-356",
    ],
)

prefix_rule(
    pattern = ["playwright-cli"],
    decision = "allow",
    justification = "Playwright CLI drives local browser verification for protospy and needs host browser access.",
    match = [
        "playwright-cli open http://localhost:5173/",
        "playwright-cli snapshot",
        "playwright-cli console",
        "playwright-cli close",
    ],
)

prefix_rule(
    pattern = ["just", "ui", "test-browser"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "just ui test-browser",
    ],
)

prefix_rule(
    pattern = ["pnpm", ["test:browser", "test:browser:headed"]],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "pnpm test:browser",
        "pnpm test:browser --reporter=dot",
        "pnpm test:browser:headed",
    ],
)

prefix_rule(
    pattern = ["pnpm", "exec", "playwright", "test"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "pnpm exec playwright test",
        "pnpm exec playwright test --headed",
        "pnpm exec playwright test browser/design-tokens.spec.ts",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "pnpm test:browser --reporter=dot"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'pnpm test:browser --reporter=dot'",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "pnpm test:browser"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'pnpm test:browser'",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "pnpm test:browser:headed"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'pnpm test:browser:headed'",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "cd ui && pnpm test:browser --reporter=dot"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'cd ui && pnpm test:browser --reporter=dot'",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "cd ui && pnpm test:browser"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'cd ui && pnpm test:browser'",
    ],
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "just ui test-browser"],
    decision = "allow",
    justification = "Playwright browser tests must run outside the macOS sandbox because Chromium Mach-port registration is blocked.",
    match = [
        "/bin/zsh -lc 'just ui test-browser'",
    ],
)
